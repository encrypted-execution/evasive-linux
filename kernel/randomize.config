# Kernel config fragment — every randomization knob we can flip.
# Appended on top of kernel/livepatch.config in demo 03.

# KASLR for the kernel base (text/rodata/data placement).
CONFIG_RANDOMIZE_BASE=y

# Randomize the direct-map / vmemmap / vmalloc base addresses.
CONFIG_RANDOMIZE_MEMORY=y

# Virtually mapped kernel stacks (gives stacks their own KASLR slot).
CONFIG_VMAP_STACK=y

# Per-syscall kernel stack offset (PaX RANDKSTACK analog, mainlined 5.13).
CONFIG_RANDOMIZE_KSTACK_OFFSET=y
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y

# Stack canaries with per-task random values.
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# Slab freelist randomization.
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y

# Full kernel struct-layout randomization via the GCC plugin (per-build).
CONFIG_HAVE_GCC_PLUGINS=y
CONFIG_GCC_PLUGINS=y
CONFIG_GCC_PLUGIN_RANDSTRUCT=y
# CONFIG_RANDSTRUCT_NONE is not set
CONFIG_RANDSTRUCT_FULL=y
CONFIG_RANDSTRUCT=y

# Make the SLAB heap less predictable too.
CONFIG_SLUB=y
