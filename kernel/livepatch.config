# Kernel config fragment for evasive-linux demo 01: a single livepatch.
#
# Appended to a `make tinyconfig`-derived base. Enables CONFIG_LIVEPATCH
# and the canonical `samples/livepatch/livepatch-sample.ko` example
# (overrides cmdline_proc_show — observable via `cat /proc/cmdline`).

# Architecture + bootability essentials.
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_TTY=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
# CONFIG_X86_X32_ABI is not set

# Module support — livepatch is delivered as a kernel module.
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# Symbol resolution for livepatch (needs static-symbol lookup).
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# Ftrace + dynamic ftrace — the redirection plumbing livepatch uses.
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_DYNAMIC_FTRACE_WITH_REGS=y

# Reliable stacktrace (ORC unwinder on x86_64) — required for the
# unified consistency model.
CONFIG_UNWINDER_ORC=y
# CONFIG_UNWINDER_FRAME_POINTER is not set

# The livepatch subsystem itself + the in-tree sample.
CONFIG_LIVEPATCH=y
CONFIG_SAMPLES=y
CONFIG_SAMPLE_LIVEPATCH=m

# Kprobes — required for evasive-linux's honey-trap arm/disarm at
# superseded function addresses. Without this, register_kprobe() is a
# static inline that returns -EOPNOTSUPP (module still compiles, trap
# never installs).
CONFIG_KPROBES=y
CONFIG_OPTPROBES=y
CONFIG_KPROBE_EVENTS=y
